SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=3001
FRONTEND_URL=http://localhost:3000

# ===================================
# CONFIGURACIÓN DE EMAIL (Microsoft/Azure)
# ===================================
# Dejar vacío para modo simulación (logging)
# Cuando tengan las credenciales de Azure AD, configurar:
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_EMAIL_FROM=noreply@abent3t.com

# ===================================
# CONFIGURACIÓN DE RECORDATORIOS
# ===================================
REMINDERS_ENABLED=true
REMINDER_FIRST_DAYS=3       # Días después de terminar curso para primer recordatorio
REMINDER_FOLLOWUP_DAYS=7    # Días para recordatorio de seguimiento
REMINDER_ESCALATION_DAYS=14 # Días para escalar a RRHH
